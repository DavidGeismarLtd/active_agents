# PromptTracker Dummy App - Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================================================================
# LLM Provider API Keys
# ===========================================================================
OPENAI_LOUNA_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# ===========================================================================
# AWS Lambda Configuration (for Function Execution)
# ===========================================================================
# Required only if you enable the 'functions' feature flag
# See docs/aws_lambda_setup.md for setup instructions

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
LAMBDA_EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/PromptTrackerLambdaExecutionRole
LAMBDA_FUNCTION_PREFIX=prompt-tracker

# ===========================================================================
# Optional Configuration
# ===========================================================================
# PROMPT_TRACKER_USERNAME=admin
# PROMPT_TRACKER_PASSWORD=secret

