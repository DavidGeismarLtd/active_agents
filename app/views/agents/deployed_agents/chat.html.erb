<div class="chat-container" data-controller="prompt-tracker--agent-chat" data-prompt-tracker--agent-chat-slug-value="<%= @agent.slug %>">
  <!-- Header -->
  <div class="chat-header">
    <h4 class="mb-1"><%= @agent.name %></h4>
    <small class="opacity-75">
      Powered by <%= @agent.prompt_version.model_config[:model] %>
    </small>
  </div>

  <!-- Messages -->
  <div class="chat-messages" data-prompt-tracker--agent-chat-target="messages">
    <!-- Welcome message -->
    <div class="message assistant">
      <div class="message-avatar">AI</div>
      <div class="message-content">
        <p class="mb-0">Hello! I'm <%= @agent.name %>. How can I help you today?</p>
      </div>
    </div>

    <!-- Typing indicator -->
    <div class="message assistant">
      <div class="message-avatar">AI</div>
      <div class="typing-indicator" data-prompt-tracker--agent-chat-target="typingIndicator">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>
  </div>

  <!-- Input -->
  <div class="chat-input-container">
    <form data-action="submit->prompt-tracker--agent-chat#sendMessage" data-prompt-tracker--agent-chat-target="form">
      <div class="input-group">
        <input
          type="text"
          class="form-control"
          placeholder="Type your message..."
          data-prompt-tracker--agent-chat-target="input"
          autocomplete="off"
          required>
        <button class="btn btn-primary" type="submit" data-prompt-tracker--agent-chat-target="sendButton">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576 6.636 10.07Zm6.787-8.201L1.591 6.602l4.339 2.76 7.494-7.493Z"/>
          </svg>
        </button>
      </div>
    </form>
  </div>
</div>
