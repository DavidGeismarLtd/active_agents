<div class="container-fluid py-4">
  <!-- Header -->
  <div class="mb-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Functions", functions_path %></li>
        <li class="breadcrumb-item active" aria-current="page"><%= @function.name %></li>
      </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h1 class="h2 mb-1">
          <i class="bi bi-code-square"></i> <%= @function.name %>
        </h1>
        <p class="text-muted"><%= @function.description %></p>
        <div class="mt-2">
          <span class="badge bg-info"><%= @function.category.titleize %></span>
          <code class="ms-2"><%= @function.language.upcase %></code>
          <% @function.tags.each do |tag| %>
            <span class="badge bg-secondary ms-1"><%= tag %></span>
          <% end %>

          <!-- Deployment Status Badge -->
          <span class="badge bg-<%= @function.deployment_status_badge_class %> ms-2">
            <%= @function.deployment_status_text %>
          </span>
        </div>
      </div>
      <div class="d-flex gap-2">
        <!-- Deployment Controls -->
        <% if @function.deployed? %>
          <%= button_to undeploy_function_path(@function), method: :delete, class: "btn btn-outline-warning", data: { confirm: "Are you sure you want to remove this function from AWS Lambda?" } do %>
            <i class="bi bi-cloud-slash"></i> Unpublish from Lambda
          <% end %>
        <% elsif @function.deploying? %>
          <button class="btn btn-warning" disabled>
            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            Deploying...
          </button>
        <% else %>
          <%= button_to deploy_function_path(@function), method: :post, class: "btn btn-success" do %>
            <i class="bi bi-cloud-upload"></i> Publish to Lambda
          <% end %>
        <% end %>

        <%= link_to edit_function_path(@function), class: "btn btn-outline-primary" do %>
          <i class="bi bi-pencil"></i> Edit
        <% end %>
        <%= button_to function_path(@function), method: :delete, class: "btn btn-outline-danger", data: { confirm: "Are you sure you want to delete this function?" } do %>
          <i class="bi bi-trash"></i> Delete
        <% end %>
      </div>
    </div>
  </div>

  <!-- Deployment Error Alert -->
  <% if @function.deployment_failed? && @function.deployment_error.present? %>
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
      <h5 class="alert-heading"><i class="bi bi-exclamation-triangle"></i> Deployment Failed</h5>
      <p class="mb-0"><%= @function.deployment_error %></p>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <!-- Stats -->
  <div class="row mb-4">
    <div class="col-md-3">
      <div class="card">
        <div class="card-body">
          <h6 class="text-muted mb-2">Total Executions</h6>
          <h3 class="mb-0"><%= number_with_delimiter(@total_executions) %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card">
        <div class="card-body">
          <h6 class="text-muted mb-2">Success Rate</h6>
          <h3 class="mb-0">
            <% if @total_executions > 0 %>
              <span class="badge <%= @success_rate >= 90 ? 'bg-success' : @success_rate >= 70 ? 'bg-warning' : 'bg-danger' %>" style="font-size: 1.5rem;">
                <%= number_to_percentage(@success_rate, precision: 1) %>
              </span>
            <% else %>
              <span class="text-muted">N/A</span>
            <% end %>
          </h3>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card">
        <div class="card-body">
          <h6 class="text-muted mb-2">Avg Execution Time</h6>
          <h3 class="mb-0">
            <% if @avg_execution_time %>
              <%= number_with_precision(@avg_execution_time, precision: 0) %>ms
            <% else %>
              <span class="text-muted">N/A</span>
            <% end %>
          </h3>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card">
        <div class="card-body">
          <h6 class="text-muted mb-2">Last Executed</h6>
          <h3 class="mb-0" style="font-size: 1rem;">
            <% if @function.last_executed_at %>
              <%= time_ago_in_words(@function.last_executed_at) %> ago
            <% else %>
              <span class="text-muted">Never</span>
            <% end %>
          </h3>
        </div>
      </div>
    </div>
  </div>

  <!-- Code -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">Function Code</h5>
    </div>
    <div class="card-body">
      <div data-controller="monaco-editor"
           data-monaco-editor-language-value="<%= @function.language %>"
           data-monaco-editor-height-value="500px"
           data-monaco-editor-minimap-value="true"
           data-monaco-editor-read-only-value="true">
        <div data-monaco-editor-target="container"></div>
        <textarea data-monaco-editor-target="textarea" class="d-none"><%= @function.code %></textarea>
      </div>
    </div>
  </div>

  <!-- Parameters -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">Parameters</h5>
    </div>
    <div class="card-body">
      <% if @function.parameters.present? %>
        <div data-controller="monaco-editor"
             data-monaco-editor-language-value="json"
             data-monaco-editor-height-value="250px"
             data-monaco-editor-minimap-value="false"
             data-monaco-editor-read-only-value="true">
          <div data-monaco-editor-target="container"></div>
          <textarea data-monaco-editor-target="textarea" class="d-none"><%= JSON.pretty_generate(@function.parameters) %></textarea>
        </div>
      <% else %>
        <p class="text-muted">No parameters defined</p>
      <% end %>
    </div>
  </div>

  <!-- Environment Variables -->
  <% if @function.environment_variables.present? %>
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="mb-0">
          <i class="bi bi-shield-lock"></i> Environment Variables
        </h5>
      </div>
      <div class="card-body">
        <div class="alert alert-info">
          <i class="bi bi-info-circle"></i> Environment variables are encrypted and cannot be displayed for security reasons.
        </div>
        <p class="mb-0">Configured variables: <strong><%= @function.environment_variables.keys.join(", ") %></strong></p>
      </div>
    </div>
  <% end %>

  <!-- Dependencies -->
  <% if @function.dependencies.present? %>
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="mb-0">Dependencies</h5>
      </div>
      <div class="card-body">
        <ul class="mb-0">
          <% @function.dependencies.each do |dep| %>
            <li><code><%= dep %></code></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <!-- Test Function -->
  <div class="card mb-4" data-controller="function-test">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-play-circle"></i> Test Function
      </h5>
    </div>
    <div class="card-body">
      <p class="text-muted">
        Test your function with custom arguments. This will deploy the function to AWS Lambda and execute it.
      </p>

      <%= form_with url: test_function_path(@function), method: :post, data: { function_test_target: "form" } do |f| %>
        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :arguments, "Test Arguments (JSON)", class: "form-label" %>
            <div data-controller="monaco-editor"
                 data-monaco-editor-language-value="json"
                 data-monaco-editor-height-value="300px"
                 data-monaco-editor-minimap-value="false">
              <div data-monaco-editor-target="container"></div>
              <%= f.text_area :arguments,
                              value: @function.example_input.present? ? JSON.pretty_generate(@function.example_input) : "{}",
                              data: { monaco_editor_target: "textarea" },
                              class: "d-none" %>
            </div>
            <div class="form-text">
              Provide arguments matching the function's parameter schema
            </div>
          </div>

          <div class="col-md-6">
            <label class="form-label">Expected Parameters</label>
            <% if @function.parameters.present? && @function.parameters["properties"].present? %>
              <div class="bg-light p-3 rounded">
                <% @function.parameters["properties"].each do |param_name, param_schema| %>
                  <div class="mb-2">
                    <code><%= param_name %></code>
                    <span class="badge bg-secondary"><%= param_schema["type"] %></span>
                    <% if @function.parameters.dig("required")&.include?(param_name) %>
                      <span class="badge bg-danger">required</span>
                    <% end %>
                    <% if param_schema["description"].present? %>
                      <div class="text-muted small"><%= param_schema["description"] %></div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted">No parameters defined</p>
            <% end %>
          </div>
        </div>

        <div class="mt-3">
          <%= f.submit "Run Test", class: "btn btn-primary", data: { function_test_target: "submitButton" } %>
          <% if @function.example_input.present? %>
            <button type="button" class="btn btn-outline-secondary" data-action="click->function-test#loadExample">
              <i class="bi bi-arrow-clockwise"></i> Load Example Input
            </button>
          <% end %>
        </div>
      <% end %>

      <!-- Test Result -->
      <div data-function-test-target="result" class="mt-4" style="display: none;">
        <hr>
        <h6>Test Result</h6>
        <div data-function-test-target="resultContent"></div>
      </div>
    </div>
  </div>

  <!-- Example -->
  <% if @function.example_input.present? || @function.example_output.present? %>
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="mb-0">Example</h5>
      </div>
      <div class="card-body">
        <div class="row">
          <% if @function.example_input.present? %>
            <div class="col-md-6">
              <h6>Input</h6>
              <pre class="bg-light p-3 rounded"><code class="language-json"><%= JSON.pretty_generate(@function.example_input) %></code></pre>
            </div>
          <% end %>
          <% if @function.example_output.present? %>
            <div class="col-md-6">
              <h6>Expected Output</h6>
              <pre class="bg-light p-3 rounded"><code class="language-json"><%= @function.example_output %></code></pre>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Execution History -->
  <div class="card">
    <div class="card-header">
      <h5 class="mb-0">Execution History</h5>
    </div>
    <div class="card-body">
      <% if @executions.any? %>
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Executed At</th>
                <th>Status</th>
                <th>Arguments</th>
                <th>Result</th>
                <th>Execution Time</th>
              </tr>
            </thead>
            <tbody>
              <% @executions.each do |execution| %>
                <tr style="cursor: pointer;" onclick="window.location='<%= function_execution_path(execution) %>'">
                  <td><%= execution.executed_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
                  <td>
                    <% if execution.success %>
                      <span class="badge bg-success">Success</span>
                    <% else %>
                      <span class="badge bg-danger">Failed</span>
                    <% end %>
                  </td>
                  <td>
                    <% if execution.arguments.present? %>
                      <code><%= truncate(execution.arguments.to_json, length: 50) %></code>
                    <% else %>
                      <span class="text-muted">None</span>
                    <% end %>
                  </td>
                  <td>
                    <% if execution.success %>
                      <code><%= truncate(execution.result.to_json, length: 50) %></code>
                    <% else %>
                      <span class="text-danger"><%= truncate(execution.error_message, length: 50) %></span>
                    <% end %>
                  </td>
                  <td class="text-end">
                    <%= number_with_precision(execution.execution_time_ms, precision: 0) %>ms
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="mt-3">
          <%= paginate @executions %>
        </div>
      <% else %>
        <div class="text-center py-5">
          <i class="bi bi-clock-history" style="font-size: 3rem; color: #ccc;"></i>
          <p class="text-muted mt-3">No execution history yet</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
