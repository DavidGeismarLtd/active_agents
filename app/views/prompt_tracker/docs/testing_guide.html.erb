                    </p>
                    <%= link_to docs_playground_guide_path, class: "btn btn-outline-info btn-sm" do %>
                      <i class="bi bi-arrow-right"></i> Playground Guide
                    <% end %>
                  </div>
                </div>
              </div>

              <div class="col-md-6">
                <div class="card h-100">
                  <div class="card-body">
