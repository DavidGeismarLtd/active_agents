              <% end %>
            </div>
            <div class="d-flex gap-2">
              <%= link_to docs_playground_guide_path, class: "btn btn-outline-info" do %>
                <i class="bi bi-flask"></i> Playground Guide
              <% end %>
              <%= link_to docs_tracking_path, class: "btn btn-outline-success" do %>
                <i class="bi bi-code-square"></i> Integration Guide
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
