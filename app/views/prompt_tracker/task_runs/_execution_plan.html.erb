<div id="execution_plan" class="card mb-4">
  <div class="card-header">
    <h5 class="mb-0">
      <i class="bi bi-list-check"></i> Execution Plan
      <% if task_run.metadata&.dig("plan", "status") == "completed" %>
        <span class="badge bg-success">Completed</span>
      <% elsif task_run.metadata&.dig("plan", "status") == "in_progress" %>
        <span class="badge bg-primary">In Progress</span>
      <% elsif task_run.metadata&.dig("plan", "status") == "failed" %>
        <span class="badge bg-danger">Failed</span>
      <% else %>
        <span class="badge bg-secondary">Pending</span>
      <% end %>
    </h5>
  </div>
  <div class="card-body">
    <% if task_run.metadata&.dig("plan") %>
      <% plan = task_run.metadata["plan"] %>

      <div class="mb-3">
        <strong>Goal:</strong> <%= plan["goal"] %>
      </div>

      <% failed_steps = plan["steps"].select { |s| s["status"] == "failed" } %>
      <% if failed_steps.any? %>
        <div class="alert alert-warning mb-3">
          <i class="bi bi-exclamation-triangle-fill me-2"></i>
          <strong>Warning:</strong> <%= failed_steps.size %> step<%= failed_steps.size > 1 ? 's' : '' %> failed. Check details below.
        </div>
      <% end %>

      <div class="progress mb-3" style="height: 25px;">
        <% completed = plan["steps"].count { |s| s["status"] == "completed" } %>
        <% failed = plan["steps"].count { |s| s["status"] == "failed" } %>
        <% total = plan["steps"].size %>
        <% percentage = total.zero? ? 0 : (completed.to_f / total * 100).round %>
        <% failed_percentage = total.zero? ? 0 : (failed.to_f / total * 100).round %>
        <div class="progress-bar <%= percentage == 100 ? 'bg-success' : '' %>"
             role="progressbar"
             style="width: <%= percentage %>%"
             aria-valuenow="<%= percentage %>"
             aria-valuemin="0"
             aria-valuemax="100">
          <%= completed %> / <%= total %> completed
        </div>
        <% if failed > 0 %>
          <div class="progress-bar bg-danger"
               role="progressbar"
               style="width: <%= failed_percentage %>%"
               aria-valuenow="<%= failed_percentage %>"
               aria-valuemin="0"
               aria-valuemax="100">
            <%= failed %> failed
          </div>
        <% end %>
      </div>

      <div class="list-group">
        <% plan["steps"].each do |step| %>
          <div class="list-group-item">
            <div class="d-flex justify-content-between align-items-start">
              <div class="flex-grow-1">
                <div class="d-flex align-items-center mb-1">
                  <% case step["status"] %>
                  <% when "completed" %>
                    <i class="bi bi-check-circle-fill text-success me-2"></i>
                  <% when "in_progress" %>
                    <i class="bi bi-arrow-repeat text-primary me-2 spinner-border spinner-border-sm"></i>
                  <% when "failed" %>
                    <i class="bi bi-x-circle-fill text-danger me-2"></i>
                  <% when "skipped" %>
                    <i class="bi bi-skip-forward text-secondary me-2"></i>
                  <% else %>
                    <i class="bi bi-circle text-muted me-2"></i>
                  <% end %>
                  <strong><%= step["description"] %></strong>
                </div>

                <% if step["notes"].present? %>
                  <div class="text-muted small ms-4 mt-1">
                    <%= simple_format(step["notes"], {}, wrapper_tag: "div") %>
                  </div>
                <% end %>

                <% if step["completed_at"].present? %>
                  <div class="text-muted small ms-4 mt-1">
                    <i class="bi bi-clock"></i> Completed: <%= Time.parse(step["completed_at"]).strftime("%H:%M:%S") %>
                  </div>
                <% elsif step["started_at"].present? %>
                  <div class="text-muted small ms-4 mt-1">
                    <i class="bi bi-clock"></i> Started: <%= Time.parse(step["started_at"]).strftime("%H:%M:%S") %>
                  </div>
                <% end %>
              </div>

              <%
                # Inline status color mapping to avoid helper dependency in Turbo Stream context
                status_color = case step["status"]
                when "completed" then "success"
                when "in_progress" then "primary"
                when "failed" then "danger"
                when "skipped" then "warning"
                else "light"
                end
              %>
              <span class="badge bg-<%= status_color %>">
                <%= step["status"].titleize %>
              </span>
            </div>
          </div>
        <% end %>
      </div>

      <% if plan["completion_summary"].present? %>
        <div class="alert alert-<%= plan["status"] == "completed" ? "success" : "danger" %> mt-3 mb-0">
          <strong><%= plan["status"] == "completed" ? "Summary:" : "Error:" %></strong>
          <%= simple_format(plan["completion_summary"], {}, wrapper_tag: "div") %>
        </div>
      <% end %>
    <% else %>
      <div class="text-center text-muted py-4">
        <i class="bi bi-hourglass-split fs-1 d-block mb-2"></i>
        <p class="mb-0">No plan created yet. Waiting for agent to create plan...</p>
      </div>
    <% end %>
  </div>
</div>
