<%# Timeline content - extracted for Turbo Stream updates %>
<div class="card-body" id="execution_timeline">
	  <% if timeline.any? %>
		  <div class="timeline-container">
		    <% timeline.each do |iteration| %>
		      <%= render "prompt_tracker/task_runs/iteration_group", iteration: iteration %>
		    <% end %>
		  </div>

		  <%# Final status banner (cancellation / max iterations / success) %>
		  <% termination_reason = task_run.metadata&.dig("termination_reason") %>
		  <% if termination_reason.present? %>
		    <div class="mt-3">
		      <% if termination_reason == "max_iterations" %>
		        <div class="alert alert-warning mb-0">
		          <i class="bi bi-stopwatch"></i>
		          Execution stopped because the maximum number of iterations was reached.
		        </div>
		      <% elsif termination_reason == "cancelled" %>
		        <div class="alert alert-secondary mb-0">
		          <i class="bi bi-slash-circle"></i>
		          Task was cancelled by the user.
		        </div>
		      <% elsif termination_reason == "success" %>
		        <div class="alert alert-success mb-0">
		          <i class="bi bi-check-circle"></i>
		          Task finished successfully.
		        </div>
		      <% end %>
		    </div>
		  <% end %>
	  <% else %>
		  <div class="alert alert-info mb-0">
		    <i class="bi bi-info-circle"></i> No execution events yet.
		  </div>
	  <% end %>
	</div>
