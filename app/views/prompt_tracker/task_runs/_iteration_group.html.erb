<%# Iteration Group - Collapsible container for all events in one iteration %>
<div class="iteration-group mb-4" data-task-timeline-target="iterationGroup">
  <!-- Iteration Header -->
  <div class="card border-primary">
    <div class="card-header bg-light cursor-pointer"
         data-action="click->task-timeline#toggleIteration"
         data-bs-toggle="collapse"
         data-bs-target="#iteration-<%= iteration[:iteration] %>">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-0">
            <% if iteration[:iteration] == 0 %>
              <i class="bi bi-lightbulb text-primary"></i>
              <strong>Planning Phase (Iteration 0)</strong>
              <span class="badge bg-success"><%= iteration[:events].count %> events</span>
            <% else %>
              <i class="bi bi-arrow-repeat"></i>
              Iteration <%= iteration[:iteration] %>
              <span class="badge bg-primary"><%= iteration[:events].count %> events</span>
            <% end %>
          </h5>
          <small class="text-muted">
            <%= iteration[:duration_ms] %>ms
            • <%= iteration[:llm_calls_count] %> LLM call<%= iteration[:llm_calls_count] == 1 ? '' : 's' %>
            • <%= iteration[:function_calls_count] %> function call<%= iteration[:function_calls_count] == 1 ? '' : 's' %>
          </small>
        </div>
        <div>
          <small class="text-muted"><%= iteration[:started_at].strftime("%H:%M:%S.%L") %></small>
          <i class="bi bi-chevron-down ms-2"></i>
        </div>
      </div>
    </div>

    <!-- Iteration Body (Collapsible) -->
    <div id="iteration-<%= iteration[:iteration] %>" class="collapse show">
      <div class="card-body p-3">
        <!-- Timeline Events -->
        <div class="timeline">
          <% iteration[:events].each_with_index do |event, index| %>
            <div class="timeline-item <%= 'mb-3' unless index == iteration[:events].length - 1 %>">
              <div class="d-flex">
                <!-- Timeline Marker -->
                <div class="timeline-marker me-3">
                  <% if event[:type] == :llm_response %>
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center"
                         style="width: 32px; height: 32px;">
                      <i class="bi bi-chat-left-text"></i>
                    </div>
                  <% elsif event[:type] == :function_execution %>
                    <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center"
                         style="width: 32px; height: 32px;">
                      <i class="bi bi-code-square"></i>
                    </div>
                  <% end %>

                  <!-- Vertical line connecting to next event -->
                  <% unless index == iteration[:events].length - 1 %>
                    <div class="timeline-line bg-secondary" style="width: 2px; height: 100%; margin-left: 15px; margin-top: 4px;"></div>
                  <% end %>
                </div>

                <!-- Event Card -->
                <div class="flex-grow-1">
                  <% if event[:type] == :llm_response %>
                    <%= render "prompt_tracker/task_runs/llm_call_card", response: event[:data], timestamp: event[:timestamp] %>
                  <% elsif event[:type] == :function_execution %>
                    <%= render "prompt_tracker/task_runs/function_execution_card", execution: event[:data], timestamp: event[:timestamp] %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.cursor-pointer {
  cursor: pointer;
}

.timeline-line {
  position: relative;
  top: 0;
}

.iteration-group .card-header:hover {
  background-color: #e9ecef !important;
}

.iteration-group .bi-chevron-down {
  transition: transform 0.2s;
}

.iteration-group .collapsed .bi-chevron-down {
  transform: rotate(-90deg);
}
</style>
