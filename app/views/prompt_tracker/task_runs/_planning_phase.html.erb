<%# Planning Phase partial - extracted for Turbo Stream updates %>
<% if agent.task_configuration.dig(:planning, :enabled) && task_run.metadata&.dig("planning_phase") %>
  <div class="card mb-4 border-primary" data-controller="task-timeline">
    <div class="card-header bg-primary bg-opacity-10">
      <div class="d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
          <i class="bi bi-lightbulb text-primary"></i>
          <strong>Planning Phase (Iteration 0)</strong>
          <% planning_phase = task_run.metadata["planning_phase"] %>
          <% if planning_phase["status"] == "completed" %>
            <span class="badge bg-success ms-2">Completed</span>
          <% elsif planning_phase["status"] == "in_progress" %>
            <span class="badge bg-primary ms-2">In Progress</span>
          <% end %>
        </h5>
        <div class="d-flex align-items-center gap-2">
          <% if planning_phase["duration_seconds"] %>
            <small class="text-muted">
              Duration: <%= (planning_phase["duration_seconds"] * 1000).round(0) %>ms
            </small>
          <% end %>
          <button type="button"
                  class="btn btn-sm btn-outline-secondary"
                  data-bs-toggle="collapse"
                  data-bs-target="#planning-phase-collapse"
                  aria-expanded="true"
                  aria-controls="planning-phase-collapse">
            <i class="bi bi-chevron-down"></i>
          </button>
        </div>
      </div>
    </div>
    <div class="collapse show" id="planning-phase-collapse">
      <div class="card-body">
        <p class="text-muted mb-3">
          <i class="bi bi-info-circle"></i>
          The agent created a plan before starting execution. This ensures structured, step-by-step progress.
        </p>

        <% # Find the planning phase LLM response (first response with create_plan call) %>
        <% planning_response = llm_responses.find { |r| r.tool_calls&.any? { |tc| tc["function_name"] == "create_plan" || tc["name"] == "create_plan" } } %>

        <% if planning_response %>
          <div class="border rounded p-3 bg-light">
            <h6 class="text-primary mb-2">
              <i class="bi bi-robot"></i> LLM Planning Call
            </h6>
            <div class="mb-2">
              <small class="text-muted">
                Model: <%= planning_response.model %> |
                Tokens: <%= planning_response.tokens_total || 'N/A' %>
              </small>
            </div>

            <% if planning_response.tool_calls&.any? %>
              <div class="mt-3">
                <strong>Function Calls:</strong>
                <% planning_response.tool_calls.each do |tc| %>
                  <div class="border rounded p-2 mt-2 bg-white">
                    <div class="d-flex justify-content-between align-items-start">
                      <span class="badge bg-primary"><%= tc["function_name"] || tc["name"] %></span>
                      <small class="text-muted"><%= planning_response.created_at.strftime("%H:%M:%S") %></small>
                    </div>
                    <% if tc["arguments"].present? %>
                      <% begin %>
                        <% args = tc["arguments"].is_a?(String) ? JSON.parse(tc["arguments"]) : tc["arguments"] %>
                        <pre class="mb-0 mt-2 small code-block-scrollable"><code><%= JSON.pretty_generate(args) %></code></pre>
                      <% rescue JSON::ParserError %>
                        <pre class="mb-0 mt-2 small code-block-scrollable"><code><%= tc["arguments"] %></code></pre>
                      <% end %>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="alert alert-warning mb-0">
            <i class="bi bi-exclamation-triangle"></i> Planning phase data not found in LLM responses.
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
