<% content_for :breadcrumbs do %>
  <li class="breadcrumb-item"><%= link_to "Deployed Agents", deployed_agents_path %></li>
  <li class="breadcrumb-item active"><%= @agent.name %></li>
<% end %>

<div class="deployed-agent-show">
  <!-- Header -->
  <div class="page-header" style="background-color: #F3E8FF; border-left: 4px solid #9333EA; padding: 1.5rem; margin-bottom: 2rem;">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h1 style="color: #581C87; margin: 0;">
          <i class="bi bi-robot"></i> <%= @agent.name %>
          <% case @agent.status %>
          <% when "active" %>
            <span class="badge bg-success">Active</span>
          <% when "paused" %>
            <span class="badge bg-warning">Paused</span>
          <% when "error" %>
            <span class="badge bg-danger">Error</span>
          <% end %>
        </h1>
        <div style="margin-top: 0.5rem;">
          <code style="background-color: #E9D5FF; color: #581C87; padding: 0.25rem 0.5rem; border-radius: 0.25rem; font-size: 0.875rem;">
            slug: "<%= @agent.slug %>"
          </code>
        </div>
        <p style="color: #581C87; margin: 0.5rem 0 0 0;">
          Deployed <%= time_ago_in_words(@agent.deployed_at) %> ago from
          <%= link_to "#{@prompt.name} v#{@version.version_number}",
              testing_prompt_prompt_version_path(@prompt, @version),
              style: "color: #581C87; text-decoration: underline;" %>
        </p>
      </div>
      <div class="d-flex gap-2">
        <% if @agent.status == "active" %>
          <%= button_to pause_deployed_agent_path(@agent.slug), method: :post, class: "btn btn-warning" do %>
            <i class="bi bi-pause-circle"></i> Pause
          <% end %>
        <% elsif @agent.status == "paused" %>
          <%= button_to resume_deployed_agent_path(@agent.slug), method: :post, class: "btn btn-success" do %>
            <i class="bi bi-play-circle"></i> Resume
          <% end %>
        <% end %>
        <%= link_to edit_deployed_agent_path(@agent.slug), class: "btn btn-outline-primary" do %>
          <i class="bi bi-gear"></i> Settings
        <% end %>
        <%= button_to deployed_agent_path(@agent.slug), method: :delete, class: "btn btn-outline-danger",
            data: { confirm: "Are you sure? This will delete the agent and all its conversations." } do %>
          <i class="bi bi-trash"></i> Delete
        <% end %>
      </div>
    </div>
  </div>

  <!-- Statistics Cards -->
  <div class="row mb-4">
    <% if @agent.agent_type_task? %>
      <!-- Task Agent Statistics -->
      <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h6 class="text-muted mb-2"><i class="bi bi-play-circle"></i> Total Runs</h6>
            <h3 class="mb-0"><%= number_with_delimiter(@total_runs) %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h6 class="text-muted mb-2"><i class="bi bi-check-circle"></i> Successful</h6>
            <h3 class="mb-0 text-success"><%= number_with_delimiter(@successful_runs) %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h6 class="text-muted mb-2"><i class="bi bi-x-circle"></i> Failed</h6>
            <h3 class="mb-0 text-danger"><%= number_with_delimiter(@failed_runs) %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h6 class="text-muted mb-2"><i class="bi bi-arrow-repeat"></i> Running</h6>
            <h3 class="mb-0 text-primary"><%= number_with_delimiter(@running_runs) %></h3>
          </div>
        </div>
      </div>
    <% else %>
      <!-- Conversational Agent Statistics -->
      <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h6 class="text-muted mb-2"><i class="bi bi-chat-dots"></i> Total Conversations</h6>
            <h3 class="mb-0"><%= number_with_delimiter(@total_conversations) %></h3>
            <small class="text-success"><%= @active_conversations %> active</small>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h6 class="text-muted mb-2"><i class="bi bi-arrow-repeat"></i> Total Requests</h6>
            <h3 class="mb-0"><%= number_with_delimiter(@total_requests) %></h3>
            <small class="text-success"><%= @successful_requests %> successful</small>
            <small class="text-danger ms-2"><%= @failed_requests %> failed</small>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h6 class="text-muted mb-2"><i class="bi bi-speedometer2"></i> Avg Response Time</h6>
            <h3 class="mb-0">
              <% if @avg_response_time %>
                <%= @avg_response_time %>ms
              <% else %>
                <span class="text-muted">N/A</span>
              <% end %>
            </h3>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h6 class="text-muted mb-2"><i class="bi bi-clock-history"></i> Last Request</h6>
            <h3 class="mb-0" style="font-size: 1.2rem;">
              <% if @agent.last_request_at %>
                <%= time_ago_in_words(@agent.last_request_at) %> ago
              <% else %>
                <span class="text-muted">Never</span>
              <% end %>
            </h3>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Tabs -->
  <ul class="nav nav-tabs mb-4" id="agentTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview" type="button" role="tab">
        <i class="bi bi-info-circle"></i> Overview
      </button>
    </li>
    <% if @agent.agent_type_task? %>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="schedules-tab" data-bs-toggle="tab" data-bs-target="#schedules" type="button" role="tab">
          <i class="bi bi-calendar-event"></i> Schedules
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="runs-tab" data-bs-toggle="tab" data-bs-target="#runs" type="button" role="tab">
          <i class="bi bi-list-check"></i> Run History
        </button>
      </li>
    <% else %>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="logs-tab" data-bs-toggle="tab" data-bs-target="#logs" type="button" role="tab">
          <i class="bi bi-list-ul"></i> Logs
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="conversations-tab" data-bs-toggle="tab" data-bs-target="#conversations" type="button" role="tab">
          <i class="bi bi-chat-dots"></i> Conversations
        </button>
      </li>
    <% end %>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="functions-tab" data-bs-toggle="tab" data-bs-target="#functions" type="button" role="tab">
        <i class="bi bi-code-square"></i> Functions
      </button>
    </li>
  </ul>

  <!-- Tab Content -->
  <div class="tab-content" id="agentTabsContent">
    <!-- Overview Tab -->
    <div class="tab-pane fade show active" id="overview" role="tabpanel">
      <%= render "prompt_tracker/deployed_agents/tabs/overview", agent: @agent, prompt: @prompt, version: @version %>
    </div>

    <% if @agent.agent_type_task? %>
      <!-- Schedules Tab (Task Agents Only) -->
      <div class="tab-pane fade" id="schedules" role="tabpanel">
        <%= render "prompt_tracker/deployed_agents/tabs/schedules", agent: @agent, task_schedules: @task_schedules %>
      </div>

      <!-- Run History Tab (Task Agents Only) -->
      <div class="tab-pane fade" id="runs" role="tabpanel">
        <%= render "prompt_tracker/deployed_agents/tabs/runs", agent: @agent, recent_task_runs: @recent_task_runs %>
      </div>
    <% else %>
      <!-- Logs Tab (Conversational Agents Only) -->
      <div class="tab-pane fade" id="logs" role="tabpanel">
        <%= render "prompt_tracker/deployed_agents/tabs/logs", agent: @agent, recent_responses: @recent_responses %>
      </div>

      <!-- Conversations Tab (Conversational Agents Only) -->
      <div class="tab-pane fade" id="conversations" role="tabpanel">
        <%= render "prompt_tracker/deployed_agents/tabs/conversations", agent: @agent, recent_conversations: @recent_conversations %>
      </div>
    <% end %>

    <!-- Functions Tab (Both Agent Types) -->
    <div class="tab-pane fade" id="functions" role="tabpanel">
      <%= render "prompt_tracker/deployed_agents/tabs/functions", agent: @agent %>
    </div>
  </div>
</div>

<% if @agent.agent_type_task? %>
  <!-- Run Now Modal (Task Agents Only) -->
  <div data-controller="modal-fix">
    <div class="modal fade" id="runNowModal" tabindex="-1" data-modal-fix-target="modal">
      <div class="modal-dialog">
        <div class="modal-content">
          <%= form_with url: run_now_deployed_agent_path(@agent.slug), method: :post, local: true do |f| %>
            <div class="modal-header">
              <h5 class="modal-title"><i class="bi bi-play-fill"></i> Run Task Now</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <p class="text-muted">
                Configure execution parameters for this run. Leave empty to use defaults.
              </p>

              <div class="mb-3">
                <label for="max_iterations_override" class="form-label fw-bold">
                  Max Iterations
                  <span class="text-muted fw-normal">- Optional</span>
                </label>
                <%= f.number_field :max_iterations,
                    id: "max_iterations_override",
                    class: "form-control",
                    min: 1,
                    max: 50,
                    placeholder: @agent.task_config.dig(:execution, :max_iterations) || 5 %>
                <small class="text-muted">
                  Default: <%= @agent.task_config.dig(:execution, :max_iterations) || 5 %> iterations.
                  Maximum number of autonomous loops the agent can execute.
                </small>
              </div>

              <div class="mb-3">
                <label class="form-label fw-bold">Default Variables</label>
                <pre class="bg-light p-2 rounded"><code><%= JSON.pretty_generate(@agent.task_config[:variables] || {}) %></code></pre>
              </div>

              <div class="mb-3">
                <label for="variables_override" class="form-label fw-bold">
                  Variable Overrides (JSON)
                  <span class="text-muted fw-normal">- Optional</span>
                </label>
                <%= f.text_area :variables,
                    id: "variables_override",
                    class: "form-control font-monospace",
                    rows: 6,
                    placeholder: '{\n  "source_url": "https://example.com",\n  "topic": "AI agents"\n}' %>
                <small class="text-muted">
                  Only specify variables you want to override. These will be merged with defaults.
                </small>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <%= f.submit "Run Task", class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
