<div class="runs-tab">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-list-check"></i> Recent Task Runs</h4>
    <div class="d-flex gap-2">
      <%= button_to run_now_deployed_agent_path(agent.slug),
                    method: :post,
                    class: "btn btn-success" do %>
        <i class="bi bi-play-fill"></i> Run Now
      <% end %>
      <%= link_to deployed_agent_task_runs_path(agent.slug), class: "btn btn-outline-primary" do %>
        <i class="bi bi-list"></i> View All
      <% end %>
    </div>
  </div>

  <% if recent_task_runs.any? %>
    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th>ID</th>
            <th>Status</th>
            <th>Trigger</th>
            <th>Started</th>
            <th>Duration</th>
            <th>Iterations</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% recent_task_runs.each do |run| %>
            <tr>
              <td>
                <%= link_to "##{run.id}", deployed_agent_task_run_path(agent.slug, run) %>
              </td>
              <td>
                <% case run.status %>
                <% when "completed" %>
                  <span class="badge bg-success">Completed</span>
                <% when "failed" %>
                  <span class="badge bg-danger">Failed</span>
                <% when "running" %>
                  <span class="badge bg-primary">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                    Running
                  </span>
                <% when "queued" %>
                  <span class="badge bg-secondary">Queued</span>
                <% when "cancelled" %>
                  <span class="badge bg-warning">Cancelled</span>
                <% end %>
              </td>
              <td>
                <% case run.trigger_type %>
                <% when "manual" %>
                  <i class="bi bi-hand-index"></i> Manual
                <% when "scheduled" %>
                  <i class="bi bi-calendar-event"></i> Scheduled
                <% when "api" %>
                  <i class="bi bi-code"></i> API
                <% end %>
              </td>
              <td>
                <%= time_ago_in_words(run.created_at) %> ago
                <br>
                <small class="text-muted"><%= run.created_at.strftime("%Y-%m-%d %H:%M") %></small>
              </td>
              <td>
                <% if run.completed_at && run.started_at %>
                  <%= ((run.completed_at - run.started_at) * 1000).round(0) %>ms
                <% elsif run.started_at %>
                  <span class="text-muted">Running...</span>
                <% else %>
                  <span class="text-muted">N/A</span>
                <% end %>
              </td>
              <td>
                <% if run.iterations_count %>
                  <%= run.iterations_count %>
                <% else %>
                  <span class="text-muted">0</span>
                <% end %>
              </td>
              <td>
                <%= link_to deployed_agent_task_run_path(agent.slug, run), class: "btn btn-sm btn-outline-primary" do %>
                  <i class="bi bi-eye"></i> View
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle"></i> No task runs yet.
      <%= button_to "Run your first task", run_now_deployed_agent_path(agent.slug), method: :post, class: "btn btn-success btn-sm ms-2" %>
    </div>
  <% end %>
</div>
